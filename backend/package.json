{
  "name": "file-lite",
  "type": "module",
  "version": "1.1.2",
  "repository": "https://github.com/canwdev/file-lite.git",
  "bin": {
    "file-lite": "./dist/file-lite.min.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun --watch run src/main.ts",
    "build": "bun build --target=node --minify --outfile=dist/file-lite.min.mjs ./src/main.ts --banner '#!/usr/bin/env node\n'",
    "build:cjs": "bun build --target=node --format=cjs --outfile=dist/file-lite.min.cjs ./src/main.ts --banner '#!/usr/bin/env node\n'",
    "build:exe": "bun build --compile --minify --bytecode --outfile=dist/file-lite.exe ./src/main.ts",
    "build:auto": "bun run ./build.ts",
    "lint": "eslint src/**/*.{ts,tsx,vue} --fix",
    "publish": "npm publish --access public"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "archiver": "^7.0.1",
    "enquirer": "^2.4.1",
    "eslint": "^10.1.0",
    "eslint-plugin-format": "^1.5.0",
    "express": "^5.2.1",
    "express-history-api-fallback": "^2.2.1",
    "express-rate-limit": "^8.3.2",
    "get-port": "^7.2.0",
    "https": "^1.0.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-disk-info": "^1.3.0",
    "prettier": "3.8.1",
    "typescript": "^6.0.2"
  }
}